---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCover from '../components/PostCover.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const posts = allPosts.slice(0, 5);
const prophetPosts = allPosts
	.filter(post => post.data.layoutStyle === 'prophet')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const prophetPost = prophetPosts[0];
const leadPost = prophetPost ?? posts[0];
const leadSecondary = posts.filter(post => post.slug !== leadPost?.slug).slice(0, 2);
const bulletinPosts = posts.filter(post => post.slug !== leadPost?.slug).slice(2, 5);
const techPosts = allPosts.filter(post => post.data.category === 'Tech').slice(0, 3);
const lifePosts = allPosts.filter(post => post.data.category === 'Life').slice(0, 3);
const specialIssues = prophetPosts.filter(post => post.data.featured).slice(0, 3);
const visibleIssues = specialIssues.length > 0 ? specialIssues : prophetPosts.slice(0, 3);
---

<BaseLayout title="未来回忆录" description="weilv的时空褶皱 - 技术与生活的数字花园">
	<section class="prophet-frontpage not-prose">
		<div class="prophet-frontpage-head">
			<p class="prophet-frontpage-meta">Vol. 01 · Shanghai Bureau · Curated Dispatches</p>
			<h1>未来回忆录</h1>
			<p>一份偏向未来、仍然坚持纸张质感的私人报纸。这里不只是记录文章，而是经营一张有主版、有副刊、有社论的数字头版。</p>
		</div>

		<div class="prophet-frontpage-grid">
			{leadPost && (
				<article class="prophet-lead-story">
					<a href={`${import.meta.env.BASE_URL}blog/${leadPost.slug}`} class="block">
						<div class="prophet-lead-media">
							<PostCover 
								title={leadPost.data.title}
								image={leadPost.data.heroImage}
								category={leadPost.data.category}
								className="aspect-[16/10] w-full h-full object-cover"
							/>
						</div>
						<p class="prophet-home-kicker">{leadPost.data.layoutStyle === 'prophet' ? 'Front Page Experiment' : leadPost.data.category}</p>
						<h2>{leadPost.data.title}</h2>
						<p>{leadPost.data.description}</p>
					</a>
					<div class="prophet-lead-actions">
						<a href={`${import.meta.env.BASE_URL}blog/${leadPost.slug}`} class="prophet-home-link">
							阅读头条
						</a>
						{leadPost.data.layoutStyle === 'prophet' && (
							<span class="prophet-edition-chip">{leadPost.data.edition ?? 'Special Edition'}</span>
						)}
					</div>
				</article>
			)}

			<section class="prophet-secondary-column">
				<h3>Second Edition</h3>
				{leadSecondary.map(post => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-secondary-story">
						<span>{post.data.category}</span>
						<strong>{post.data.title}</strong>
						<em>{post.data.description}</em>
					</a>
				))}
			</section>

			<section class="prophet-bulletin-column">
				<h3>News Briefs</h3>
				{bulletinPosts.map(post => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-bulletin-item">
						<strong>{post.data.title}</strong>
						<span>{post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
					</a>
				))}
			</section>
		</div>
	</section>

	{visibleIssues.length > 0 && (
		<section class="prophet-issues-strip not-prose">
			<div class="prophet-home-section-head">
				<h2>Special Editions</h2>
				<div class="flex items-center gap-4">
					<span>Front page experiments and supplements</span>
					<a href={`${import.meta.env.BASE_URL}editions`} class="text-sm font-serif tracking-[0.14em] uppercase link-underline">进入目录</a>
				</div>
			</div>
			<div class="prophet-issues-grid">
				{visibleIssues.map(post => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-issue-card">
						<span>{post.data.edition ?? 'Special Edition'}</span>
						<strong>{post.data.title}</strong>
						<p>{post.data.prophet?.deck ?? post.data.description}</p>
					</a>
				))}
			</div>
		</section>
	)}

	<section class="mt-8 md:mt-16">
		<div class="flex justify-between items-baseline mb-12 border-b border-[var(--color-border)] pb-4">
			<h2 class="text-2xl font-serif font-bold tracking-tight">最新篇章</h2>
			<a href={`${import.meta.env.BASE_URL}blog`} class="text-sm font-serif tracking-[0.18em] uppercase link-underline opacity-60 hover:opacity-100 transition-opacity">查看全部</a>
		</div>

		<div class="space-y-8 md:space-y-12">
			{posts.map((post, index) => (
				<article class={`group relative flex flex-col md:flex-row gap-6 md:gap-10 items-start p-6 -mx-6 rounded-[2rem] hover:bg-[var(--color-surface)] transition-all duration-500 animate-fade-in-up`} style={`animation-delay: ${index * 100}ms`}>
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="block md:w-[35%] shrink-0 overflow-hidden rounded-2xl">
                        <PostCover 
                            title={post.data.title} 
                            image={post.data.heroImage} 
                            category={post.data.category}
                            className="aspect-[4/3] w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                    </a>
                    
                    <div class="flex-1 flex flex-col justify-center py-2">
                        <div class="flex items-center gap-3 text-xs font-semibold text-[var(--color-secondary)] mb-4 uppercase tracking-widest">
                            <time datetime={post.data.pubDate.toISOString()}>
                                {post.data.pubDate.toLocaleDateString('en-us', {
                                    year: 'numeric',
                                    month: 'short',
                                    day: 'numeric',
                                })}
                            </time>
                            <span class="w-1 h-1 rounded-full bg-[var(--color-border)]"></span>
                            <span class="text-[var(--color-primary)]">{post.data.category}</span>
                        </div>
                        
                        <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="group/title block">
                            <h3 class="text-2xl md:text-3xl font-serif font-bold mb-3 leading-tight group-hover/title:text-[var(--color-accent)] transition-colors">
                                {post.data.title}
                            </h3>
                        </a>
                        
                        <p class="text-[var(--color-secondary)] line-clamp-2 mb-6 leading-relaxed opacity-90">
                            {post.data.description}
                        </p>
                        
                        <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="inline-flex items-center text-sm font-serif tracking-[0.14em] uppercase text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                            Read Article 
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </a>
                    </div>
				</article>
			))}
            {posts.length === 0 && (
                <div class="text-center py-20">
                    <p class="text-[var(--color-secondary)] text-lg">No posts yet. Stay tuned!</p>
                </div>
            )}
		</div>
	</section>

	<section class="prophet-section-grid not-prose">
		<section class="prophet-home-section">
			<div class="prophet-home-section-head">
				<h2>Tech Desk</h2>
				<span>Engineering, systems, layout</span>
			</div>
			<div class="space-y-5">
				{techPosts.map(post => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-desk-story">
						<strong>{post.data.title}</strong>
						<p>{post.data.description}</p>
					</a>
				))}
			</div>
		</section>
		<section class="prophet-home-section">
			<div class="prophet-home-section-head">
				<h2>Life Desk</h2>
				<span>Essays, notes, memoirs</span>
			</div>
			<div class="space-y-5">
				{lifePosts.map(post => (
					<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-desk-story">
						<strong>{post.data.title}</strong>
						<p>{post.data.description}</p>
					</a>
				))}
			</div>
		</section>
	</section>
</BaseLayout>
