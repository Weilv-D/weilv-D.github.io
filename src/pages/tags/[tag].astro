---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCover from '../../components/PostCover.astro';
import PretextMagazineTitle from '../../components/PretextMagazineTitle';
import PretextCascadeBody from '../../components/PretextCascadeBody';
import ScrollReveal from '../../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { sortByDateDesc } from '../../utils/content';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags ?? []))];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => (post.data.tags ?? []).includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const sortedPosts = sortByDateDesc(posts);
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={`标签: ${tag} | 未来回忆录`} description={`关于 ${tag} 的文章`}>
    <section>
        <div class="mb-16 md:mb-20">
            <div class="flex items-center gap-4 mb-8">
                <div class="golden-line golden-line-animated"></div>
                <span class="text-[10px] font-sans uppercase tracking-[0.3em] text-[var(--color-secondary)] opacity-50">Column</span>
            </div>
            <div class="flex items-baseline gap-4 flex-wrap">
                <PretextMagazineTitle
                    client:visible
                    text={`#${tag}`}
                    as="h1"
                    className="text-4xl md:text-5xl font-display font-bold text-[var(--color-primary)] tracking-tight"
                    reveal={true}
                    revealDelay={100}
                    charStagger={50}
                />
                <span class="text-[var(--color-secondary)] text-sm font-sans uppercase tracking-wide opacity-60">{posts.length} 篇文章</span>
            </div>
            <div class="mt-6 max-w-lg">
                <PretextCascadeBody
                    client:visible
                    text={`探索与 ${tag} 相关的所有文章。这里是关于这一主题的完整档案。`}
                    className="text-base text-[var(--color-secondary)] leading-[1.9] opacity-70 font-serif"
                    wordStagger={40}
                />
            </div>
            <a href={`${baseUrl}tags`} class="inline-block mt-6 text-sm font-sans font-semibold tracking-wide link-underline text-[var(--color-secondary)] hover:text-[var(--color-primary)] transition-colors uppercase">查看所有标签</a>
        </div>
        
        <div class="space-y-16 md:space-y-20">
            {sortedPosts.map((post, index) => {
                const isEven = index % 2 === 1;
                return (
                    <article class={`group relative flex flex-col ${isEven ? 'md:flex-row-reverse' : 'md:flex-row'} gap-8 md:gap-12 items-start reveal`} data-reveal>
                        <a href={`${baseUrl}blog/${post.slug}`} class={`block ${isEven ? 'md:w-[45%]' : 'md:w-[48%]'} shrink-0 w-full overflow-hidden border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors`}>
                            <PostCover 
                                title={post.data.title} 
                                image={post.data.heroImage} 
                                category={post.data.category}
                                className="aspect-[4/3] w-full h-full object-cover img-magazine"
                            />
                        </a>
                        <div class="flex-1 flex flex-col justify-center py-1">
                            <div class="flex items-center gap-3 text-[10px] font-sans font-semibold text-[var(--color-secondary)] mb-5 uppercase tracking-[0.15em]">
                                <time datetime={post.data.pubDate.toISOString()}>
                                    {formatDate(post.data.pubDate)}
                                </time>
                                <span class="w-1 h-1 bg-[var(--color-accent)] opacity-50"></span>
                                <span class="text-[var(--color-primary)]">{post.data.category}</span>
                            </div>
                            <a href={`${baseUrl}blog/${post.slug}`} class="group/title block mb-4">
                                <h2 class="text-2xl md:text-[1.75rem] leading-snug font-display font-bold text-[var(--color-primary)] group-hover/title:text-[var(--color-accent)] transition-colors duration-300">
                                    {post.data.title}
                                </h2>
                            </a>
                            <p class="text-[var(--color-secondary)] line-clamp-2 mb-6 leading-relaxed opacity-80 text-base">
                                {post.data.description}
                            </p>
                            <a href={`${baseUrl}blog/${post.slug}`} class="inline-flex items-center text-sm font-sans font-semibold tracking-wide text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors group/link uppercase">
                                <span class="link-underline">Read Article</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </article>
                );
            })}
        </div>
    </section>
	<ScrollReveal threshold={0.1} />
</BaseLayout>
