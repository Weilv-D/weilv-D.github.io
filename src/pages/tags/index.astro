---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags ?? []))];
const pageTitle = "标签索引";
---

<BaseLayout title={`${pageTitle} | 未来回忆录`} description="按标签浏览文章">
    <section class="max-w-4xl mx-auto text-center py-16">
        <h1 class="text-5xl font-serif font-bold mb-16 tracking-tight">标签索引</h1>
        <div class="flex flex-wrap justify-center gap-4">
            {tags.map((tag) => (
                <a href={`${import.meta.env.BASE_URL}tags/${tag}`} class="group relative px-6 py-3 rounded-full border border-[var(--color-border)] hover:border-[var(--color-primary)] bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm transition-all duration-300 hover:scale-105 hover:shadow-lg">
                    <span class="text-sm font-medium text-[var(--color-secondary)] group-hover:text-[var(--color-primary)] transition-colors">#{tag}</span>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>
