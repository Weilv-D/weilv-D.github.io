---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const editions = (await getCollection('blog'))
  .filter(post => post.data.layoutStyle === 'prophet')
  .sort((a, b) => {
    const aIssue = a.data.issueNumber ?? 0;
    const bIssue = b.data.issueNumber ?? 0;
    if (aIssue !== bIssue) return bIssue - aIssue;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
const grouped = Object.entries(
  editions.reduce<Record<string, typeof editions>>((acc, post) => {
    const key = post.data.series ?? 'Prophet';
    acc[key] ??= [];
    acc[key]!.push(post);
    return acc;
  }, {}),
);
---

<BaseLayout title="Special Editions | 未来回忆录" description="预言家日报式专题增刊与副刊目录">
  <section class="prophet-editions-page not-prose">
    <header class="prophet-editions-head">
      <p class="prophet-frontpage-meta">Special Editions Archive</p>
      <h1>增刊目录</h1>
      <p>这里收录 `Prophet` 系列的头版实验、城市副刊与人物通讯。它们共享同一套排版引擎，但各自拥有不同的版心与叙事节奏。</p>
    </header>

    {grouped.map(([series, posts]) => (
      <section class="prophet-editions-group">
        <div class="prophet-home-section-head">
          <h2>{series}</h2>
          <span>{posts.length} issues archived</span>
        </div>
        <div class="prophet-editions-list">
          {posts.map((post, index) => (
            <article class="prophet-edition-entry">
              <div class="prophet-edition-entry-meta">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <div class="prophet-edition-entry-body">
                <p class="prophet-home-kicker">{post.data.edition ?? 'Special Edition'}</p>
                <h2>{post.data.title}</h2>
                <p>{post.data.prophet?.deck ?? post.data.description}</p>
                <div class="prophet-edition-series-line">
                  <span>{post.data.series ?? 'Prophet'}</span>
                  <span>{post.data.issueNumber ? `No. ${String(post.data.issueNumber).padStart(2, '0')}` : 'Issue Unnumbered'}</span>
                  {post.data.featured && <span>Featured</span>}
                </div>
                <div class="prophet-edition-entry-tags">
                  {post.data.tags.map(tag => <span>#{tag}</span>)}
                </div>
              </div>
              <div class="prophet-edition-entry-action">
                <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="prophet-home-link">阅读本期</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
