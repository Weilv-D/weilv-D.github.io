---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop';
interface Props {
	title: string;
	description: string;
    image?: string;
    wide?: boolean;
}

const { title, description, image, wide = false } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={image} />

	</head>
	<body class="flex flex-col min-h-screen relative overflow-x-hidden xuanzhi-texture">
		<Header />
		<main class={`flex-grow w-full mx-auto px-5 md:px-10 py-14 md:py-20 relative z-10 ${wide ? 'max-w-6xl' : 'max-w-5xl'}`}>
			<slot />
		</main>
		<Footer />
        <BackToTop client:idle />
        <script>
            import renderMathInElement from 'katex/dist/contrib/auto-render.mjs';

            document.addEventListener("astro:page-load", function() {
                renderMathInElement(document.body, {
                    delimiters: [
                        {left: '$$', right: '$$', display: true},
                        {left: '$', right: '$', display: false},
                        {left: '\\(', right: '\\)', display: false},
                        {left: '\\[', right: '\\]', display: true}
                    ],
                    throwOnError: false
                });
            });
        </script>
	</body>
</html>

<style is:global>
  /* Astro ViewTransitions — magazine-style cross-fade */
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root) {
    animation: magazineFadeOut 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  ::view-transition-new(root) {
    animation: magazineFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes magazineFadeOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-8px); }
  }

  @keyframes magazineFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
