---
const today = new Date();
---

<footer class="py-12 mt-20 border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-[var(--color-secondary)]">
        <div class="flex flex-col items-center md:items-start gap-1">
            <span class="font-serif font-bold text-lg text-[var(--color-primary)] tracking-tight">未来回忆录</span>
            <span class="opacity-80 font-light">&copy; {today.getFullYear()} weilv. All rights reserved.</span>
        </div>
        
        <div class="flex gap-8 font-medium">
            <a href={`${import.meta.env.BASE_URL}rss.xml`} class="hover:text-[var(--color-primary)] transition-colors relative group">
                RSS
                <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-primary)] transition-all group-hover:w-full"></span>
            </a>
            <a href="https://github.com/Weilv-D" target="_blank" class="hover:text-[var(--color-primary)] transition-colors relative group">
                GitHub
                <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-primary)] transition-all group-hover:w-full"></span>
            </a>
        </div>
    </div>
</footer>
