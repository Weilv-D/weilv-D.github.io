---
const { class: className } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" class={className} aria-hidden="true" role="img" aria-label="Koch Snowflake Fractal">
  <style>
    .k-bg { fill: var(--color-background); transition: fill 0.6s ease-out; }
    .k-grid-line { fill: none; stroke: var(--color-border); stroke-width: 1px; }
    .k-border-line { fill: none; stroke: var(--color-border); stroke-width: 1px; }
    .k-border-line-thin { fill: none; stroke: var(--color-border); stroke-width: 0.5px; }

    .k-txt-title { font-family: var(--font-display); font-size: 38px; fill: var(--color-text); transition: fill 0.6s ease-out; }
    .k-txt-sub { font-family: var(--font-display); font-size: 14px; font-style: italic; fill: var(--color-secondary); letter-spacing: 0.08em; transition: fill 0.6s ease-out; }
    .k-txt-label { font-family: var(--font-display); font-size: 12px; fill: var(--color-text); letter-spacing: 0.05em; font-weight: normal; transition: fill 0.6s ease-out; }

    .k-txt-accent { fill: var(--color-accent); }
    .k-txt-primary { fill: var(--color-primary); }

    .k-primary-stroke { stroke: var(--color-primary); fill: none; transition: stroke 0.6s ease-out; }
    .k-primary-fill { fill: var(--color-primary); transition: fill 0.6s ease-out; }
    .k-accent-stroke { stroke: var(--color-accent); fill: none; transition: stroke 0.6s ease-out; }
    .k-secondary-stroke { stroke: var(--color-secondary); fill: none; transition: stroke 0.6s ease-out; }

    .k-fractal-main { stroke: var(--color-primary); stroke-width: 1.5px; fill: var(--color-surface); transition: stroke 0.6s ease-out, fill 0.6s ease-out; }
    .k-fractal-layer { stroke: var(--color-secondary); stroke-width: 1px; fill: none; opacity: 0.4; transition: stroke 0.6s ease-out; }
    .k-circle-guide { stroke: var(--color-border); stroke-width: 1px; fill: none; transition: stroke 0.6s ease-out; }
    
    .k-callout-line { stroke: var(--color-accent); stroke-width: 1.5px; fill: none; opacity: 0.8; transition: stroke 0.6s ease-out; }
    .k-callout-dot { fill: var(--color-background); stroke: var(--color-accent); stroke-width: 2px; transition: fill 0.6s ease-out, stroke 0.6s ease-out; }
  </style>

  <defs>
    <pattern id="koch-grid" width="40" height="40" patternUnits="userSpaceOnUse">
