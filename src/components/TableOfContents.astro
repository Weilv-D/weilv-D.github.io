---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((heading) => heading.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc hidden xl:block sticky top-36 w-60 max-h-[calc(100vh-10rem)] overflow-y-auto" aria-label="文章目录">
    <div class="mb-6">
      <span class="text-[10px] font-sans uppercase tracking-[0.3em] text-[var(--color-secondary)] opacity-50">In This Issue</span>
      <div class="golden-line mt-3"></div>
    </div>
    <ul class="space-y-0 text-sm">
      {filteredHeadings.map((heading, index) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`group flex items-start gap-3 py-2.5 transition-all duration-300 hover:text-[var(--color-accent)] ${
              heading.depth === 3 ? 'pl-4 text-[var(--color-secondary)] text-xs font-sans opacity-70' : 'text-[var(--color-text)] font-serif'
            }`}
          >
            <span class="text-[10px] font-display text-[var(--color-accent)] opacity-30 group-hover:opacity-60 transition-opacity shrink-0 pt-0.5 w-4">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span class="truncate border-b border-transparent group-hover:border-[var(--color-accent-30)] transition-colors">
              {heading.text}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  // Highlight active TOC item on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const id = entry.target.getAttribute('id');
      const link = document.querySelector(`.toc a[href="#${id}"]`);
      if (!link) return;
      if (entry.intersectionRatio > 0) {
        link.classList.add('text-[var(--color-accent)]');
        link.querySelector('span:first-child')?.classList.add('opacity-60');
      } else {
        link.classList.remove('text-[var(--color-accent)]');
        link.querySelector('span:first-child')?.classList.remove('opacity-60');
      }
    });
  }, { rootMargin: '-80px 0px -60% 0px' });

  const observeHeadings = () => {
    observer.disconnect();
    document.querySelectorAll('h2[id], h3[id]').forEach((section) => {
      observer.observe(section);
    });
  };

  observeHeadings();

  document.addEventListener('astro:after-swap', observeHeadings);
</script>
