---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
const imageSrc = src.startsWith('/') ? import.meta.env.BASE_URL + src.slice(1) : src;
---

<figure class="prophet-inline-figure not-prose">
  <img src={imageSrc} alt={alt} class="img-liquid w-full h-auto" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
